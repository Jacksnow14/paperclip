#!/usr/bin/env python3
"""
git-credential-paperclip — git credential helper backed by the Paperclip secret vault.

Implements the `get` operation of the git-credential-helper protocol
(https://git-scm.com/docs/git-credential) for host=github.com, reading the
token from the vault (secret_vault.py) instead of a plaintext file.

Fail-safe by design: any vault error (missing key, missing record, import
failure) exits 0 with NO stdout output, so git falls through to the next
configured credential helper (e.g. `store`) instead of failing the push.

`store` and `erase` are no-ops — the vault is the source of truth and is
never written to by git itself.
"""
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

VAULT_SERVICE = "github_push_token"
VAULT_USERNAME = "Jacksnow14"


def _read_params():
    params = {}
    for line in sys.stdin:
        line = line.rstrip("\n")
        if not line:
            break
        if "=" in line:
            k, v = line.split("=", 1)
            params[k] = v
    return params


def main():
    if len(sys.argv) < 2:
        sys.exit(0)
    op = sys.argv[1]
    params = _read_params()

    if op != "get":
        sys.exit(0)

    if params.get("host") != "github.com":
        sys.exit(0)

    try:
        import secret_vault
        f = secret_vault._load_key()
        secrets = secret_vault._load_secrets(f)
        rec = secrets.get(VAULT_SERVICE)
        if not rec or not rec.get("value"):
            sys.exit(0)
        token = rec["value"]
        try:
            secret_vault._audit("get", VAULT_SERVICE, "via=git-credential-paperclip")
        except Exception:
            pass
    except Exception:
        sys.exit(0)

    sys.stdout.write(f"username={VAULT_USERNAME}\n")
    sys.stdout.write(f"password={token}\n")
    sys.exit(0)


if __name__ == "__main__":
    main()
